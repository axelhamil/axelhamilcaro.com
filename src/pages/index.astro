---
import BaseLayout from "@/layouts/base.astro";
---

<BaseLayout
  title="Axel Hamilcaro · Freelance Next.js & Lead Tech"
  description="Freelance Next.js, SaaS et lead tech sur la Touraine et remote France."
>
  <main class="min-h-svh flex items-center justify-center px-6">
    <section class="max-w-2xl text-center space-y-6">
      <span
        class="inline-block px-3 py-1 rounded-full bg-secondary text-secondary-foreground text-xs font-medium tracking-wide"
      >
        astro-migration · scaffold
      </span>
      <h1 class="text-4xl sm:text-6xl font-semibold tracking-tight">
        Axel Hamilcaro
      </h1>
      <p class="text-lg text-muted-foreground">
        Migration Astro en cours. Le contenu reviendra depuis la branche{" "}
        <code class="font-mono text-sm bg-muted px-1.5 py-0.5 rounded">
          nextjs
        </code>
        au fur et à mesure.
      </p>
      <a
        href="https://github.com/axelhamil/axelhamilcaro.com"
        class="inline-flex items-center gap-2 text-accent hover:underline underline-offset-4"
      >
        Voir le repo →
      </a>
    </section>
  </main>
</BaseLayout>
