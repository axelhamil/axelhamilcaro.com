---
import SiteLayout from "@/layouts/site.astro";
import Hero from "@/components/home/hero.astro";
import ExperienceTimeline from "@/components/home/experience-timeline.astro";
import WhatIDo from "@/components/home/what-i-do.astro";
import CaseStudies from "@/components/home/case-studies.astro";
import TrustedBy from "@/components/home/trusted-by.astro";
import TechStack from "@/components/home/tech-stack.astro";
import Faq from "@/components/home/faq.astro";

const pageTitle = "Axel Hamilcaro | Développeur Full-Stack Freelance France — Next.js & TypeScript";
const pageDescription = "Développeur full-stack freelance basé en Touraine, 100% remote France. Next.js, React, TypeScript, SaaS multi-tenant et lead tech fractional. TJM 450€.";

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Axel Hamilcaro",
  jobTitle: "Développeur Full-Stack Freelance",
  url: "https://axelhamilcaro.com",
  image: "https://axelhamilcaro.com/profil_pp.jpeg",
  email: "mailto:contact@axelhamilcaro.com",
  address: { "@type": "PostalAddress", addressRegion: "Centre-Val de Loire", addressCountry: "FR" },
  sameAs: [
    "https://github.com/axelhamil",
    "https://www.linkedin.com/in/axelhamilcaro/",
    "https://www.malt.fr/profile/axelhamilcaro",
  ],
  knowsAbout: ["Next.js", "React", "TypeScript", "Node.js", "PostgreSQL", "SaaS", "Clean Architecture", "DDD"],
};
---

<SiteLayout
  title={pageTitle}
  description={pageDescription}
  image="/og-default.png"
  imageAlt="Axel Hamilcaro — Freelance Next.js, SaaS et Lead Tech"
  type="website"
>
  <script slot="head" is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />

  <Hero />
  <ExperienceTimeline />
  <WhatIDo />
  <CaseStudies />
  <TrustedBy />
  <TechStack />
  <Faq />
</SiteLayout>
