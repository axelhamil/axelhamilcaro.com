---
import { Check, Cpu, Gauge, Layers, Shield } from "@lucide/astro";

const blocks = [
  {
    eyebrow: "Frontend",
    title: "React & Next.js",
    desc: "TypeScript strict, composants réutilisables et architecture modulaire pour une base de code évolutive.",
    icon: Layers,
    from: "#3b82f6",
    to: "#06b6d4",
    bullets: [
      "Server Components & App Router",
      "State management optimisé",
      "Tests unitaires et E2E",
    ],
  },
  {
    eyebrow: "UI/UX",
    title: "Design system moderne",
    desc: "Tailwind CSS, animations CSS pures et composants accessibles pour une expérience utilisateur premium.",
    icon: Gauge,
    from: "#f59e0b",
    to: "#ff4d00",
    bullets: [
      "Responsive mobile-first",
      "SEO technique optimisé",
      "Accessibilité WCAG",
    ],
  },
  {
    eyebrow: "Backend",
    title: "Node.js & PostgreSQL",
    desc: "APIs REST/GraphQL, authentification sécurisée et base de données performante pour des applications robustes.",
    icon: Shield,
    from: "#10b981",
    to: "#14b8a6",
    bullets: ["APIs documentées", "Authentification OAuth/JWT", "Migrations et backups"],
  },
] as const;
---

<section id="stack" class="container mx-auto px-4 py-16 sm:px-6 sm:py-24 md:px-10 scroll-mt-20" aria-labelledby="stack-title">
  <div class="mx-auto flex max-w-3xl flex-col items-center gap-3 text-center">
    <span class="badge" data-reveal="scale">
      <Cpu class="size-4 text-accent" aria-hidden="true" />
      Stack
    </span>
    <h2 id="stack-title" class="section-title" data-reveal>Technologies et expertise</h2>
    <p class="text-sm text-muted-foreground sm:text-base" data-reveal>
      Une stack moderne et éprouvée pour des applications performantes, maintenables et scalables.
    </p>
  </div>

  <div class="mx-auto mt-12 grid max-w-6xl gap-6 sm:grid-cols-1 lg:grid-cols-3">
    {
      blocks.map((b, i) => (
        <article
          class="card-accent accent-underline group flex flex-col gap-4 p-6"
          style={`--gradient-from: ${b.from}; --gradient-to: ${b.to};`}
          data-reveal={i === 0 ? "left" : i === blocks.length - 1 ? "right" : undefined}
        >
          <header class="flex items-start justify-between gap-4">
            <div class="flex flex-col gap-1">
              <span class="eyebrow">{b.eyebrow}</span>
              <h3 class="text-lg font-semibold sm:text-xl">{b.title}</h3>
            </div>
            <span class="icon-tile">
              <b.icon class="size-6" aria-hidden="true" />
            </span>
          </header>

          <p class="text-sm leading-relaxed text-secondary">{b.desc}</p>

          <ul class="flex flex-col gap-2">
            {b.bullets.map((txt) => (
              <li class="flex items-start gap-2">
                <Check class="mt-0.5 size-4 shrink-0 text-accent" aria-hidden="true" />
                <span class="text-sm">{txt}</span>
              </li>
            ))}
          </ul>
        </article>
      ))
    }
  </div>

  <div class="mt-10 flex justify-center" data-reveal="scale">
    <span class="badge">
      <Cpu class="size-4 text-accent" aria-hidden="true" />
      <span class="text-xs text-secondary sm:text-sm">
        Stack adaptable : MVP rapide, refonte progressive, SaaS multi-tenant ou app haute performance
      </span>
    </span>
  </div>
</section>

<style>
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--primary);
  }
</style>
